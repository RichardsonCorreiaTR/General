# Dados pesados e cache (OOM / tamanho)
banco-dados/dados-brutos/
scripts/cache/

# Logs e analises locais
logs/
analises-ia/

# Editor / SO
Thumbs.db
Desktop.ini
*.swp
*~

# Opcional: credenciais locais (se criar)
.env
*.local.json
# SGD: credenciais só na sua máquina (consulta Playwright)
scripts/sgd_consulta/.sgd-credentials.local
# Projeto-filho: consultas SGD por analista (credenciais, saídas pesadas, sessão)
projeto-filho/data/sgd-psai-consultas/.sgd-credentials.local
projeto-filho/data/sgd-psai-consultas/session_state*.json
projeto-filho/data/sgd-psai-consultas/consultas/

# Credenciais locais (nunca commitar)
config/conexao-odbc.json

# Cursor / IDE
.snapshots/

# Temporarios
logs-consolidado-temp.json
.commit-msg-tmp.txt
*.commit-msg.tmp

# Lock de atualizacao (evita execucoes concorrentes)
scripts/.update-lock.json

# SGD Playwright: estado de sessao (cookies) — nao versionar
scripts/sgd_consulta/data/session_state*.json
# Consultas PSAI arquivadas (HTML, capturas — podem conter dados internos)
scripts/sgd_consulta/data/consultas/arquivo/
scripts/sgd_consulta/data/consultas/logs/
# JSON de consultas PSAI locais (nao versionar saidas da ferramenta)
scripts/sgd_consulta/data/consultas/psai_*.json

# Estado / temporarios da pipeline de extracao SAIs
atualizacao/.stats-temp.json
atualizacao/.extracao-temp.json
atualizacao/log-importacao.txt
atualizacao/status.json

# Apresentacoes acidentais dentro de pacotes de atualizacao (nao versionar)
atualizacao/**/templates/*.pptx

# Output de scripts de teste
scripts/gerar-indices-output.txt
scripts/gerar-indices-error.txt
scripts/*.tmp.txt

# status-ambiente.json local (gerado por verificar-ambiente.ps1)
# Contem dados pessoais (nome, email, host, usuario_windows); nunca commitar.
projeto-filho/config/status-ambiente.json
distribuicao/ultima-versao/config/status-ambiente.json
atualizacao/**/arquivos/config/status-ambiente.json

# Junctions do projeto-filho: apontam para pastas do General (evita duplicacao no git)
projeto-filho/referencia/banco-dados/
projeto-filho/referencia/atualizacao/
projeto-filho/referencia/logs/
